// 2D. AJAX TÌM KIẾM YOUTUBE
// ==========================================
add_action('wp_ajax_cysp_search',        'cysp_handle_ajax_search');
add_action('wp_ajax_nopriv_cysp_search', 'cysp_handle_ajax_search');
function cysp_handle_ajax_search() {
    check_ajax_referer('cysp_search_secure_nonce', 'security');
    $api_key = get_option('cysp_api_key');
    if (empty($api_key)) wp_send_json_error('Chưa cấu hình YouTube API Key.');

    $query    = isset($_POST['query'])    ? sanitize_text_field($_POST['query'])    : '';
    $order    = isset($_POST['order'])    ? sanitize_text_field($_POST['order'])    : 'relevance';
    $duration = isset($_POST['duration']) ? sanitize_text_field($_POST['duration']) : 'any';
    $caption  = isset($_POST['caption'])  ? sanitize_text_field($_POST['caption'])  : 'closedCaption';
    $lang     = isset($_POST['lang'])     ? sanitize_text_field($_POST['lang'])     : 'zh-Hans';

    $api_query = $query;
    if ($caption === 'closedCaption') $api_query .= ' "中文字幕"';

    $cache_key = 'cysp_yt_v2_' . md5($api_query . $order . $duration . $caption . $lang);
    $yt_items  = get_transient($cache_key);

    if ($yt_items === false) {
        $url = "https://www.googleapis.com/youtube/v3/search?part=snippet&maxResults=12&type=video"
             . "&q=" . urlencode($api_query) . "&order=" . $order
             . "&videoDuration=" . $duration . "&relevanceLanguage=" . $lang . "&key=" . $api_key;
        if ($caption === 'closedCaption') $url .= "&videoCaption=closedCaption";

        $response = wp_remote_get($url);
        if (is_wp_error($response)) wp_send_json_error('Lỗi kết nối máy chủ.');

        $data = json_decode(wp_remote_retrieve_body($response));
        if (isset($data->error)) wp_send_json_error($data->error->message);

        $yt_items = $data->items;
        set_transient($cache_key, $yt_items, 12 * HOUR_IN_SECONDS);
    }

    $upload_dir     = wp_upload_dir();
    $transcript_dir = $upload_dir['basedir'] . '/cysp_transcripts/';
    
    // ── ƯU TIÊN VIDEO LOCAL CÓ CHỨA TỪ KHÓA (BỎ QUA KHOẢNG TRẮNG) ──
    $local_items = cysp_get_all_local_videos_metadata($api_key, $transcript_dir);
    $matched_local = [];
    if (!empty($query)) {
        $normalized_query = str_replace(' ', '', mb_strtolower($query, 'UTF-8'));
        
        foreach ($local_items as $item) {
            $title = isset($item->snippet->title) ? $item->snippet->title : '';
            $normalized_title = str_replace(' ', '', mb_strtolower($title, 'UTF-8'));
            
            if (mb_strpos($normalized_title, $normalized_query, 0, 'UTF-8') !== false) {
                $matched_local[] = $item;
            }
        }
    }

    $split_results = ['with_transcript' => [], 'without_transcript' => []];
    $seen = [];

    // Nhét các video local khớp từ khóa lên đầu (With transcript)
    foreach ($matched_local as $item) {
        $split_results['with_transcript'][] = $item;
        $seen[$item->id->videoId] = true;
    }

    // Tiếp tục xử lý kết quả YT
    foreach ($yt_items as $item) {
        if (!isset($item->id->videoId)) continue;
        $vid = $item->id->videoId;
        if (isset($seen[$vid])) continue;
        
        $has_file = file_exists($transcript_dir . $vid . '.json') || file_exists($transcript_dir . $vid . '.srt');
        if ($has_file) $split_results['with_transcript'][]    = $item;
        else           $split_results['without_transcript'][] = $item;
        $seen[$vid] = true;
    }
    
    wp_send_json_success($split_results);
}

