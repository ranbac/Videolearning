            $('#cysp-mode-toolbar').fadeIn(200);
            cyspTranscript = res.data;

            // Khởi tạo lịch sử khi load thành công transcript
            if (cyspCurrentMeta) {
                cyspUpdateHistoryRecord(vid, cyspCurrentMeta.title, cyspCurrentMeta.thumb, cyspCurrentMeta.channel, cyspTranscript.length, 0);
            }

