    function playSentenceByIndex(idx, onDone) {
        if (!cyspPlayer || !cyspTranscript.length) return;
        var seg = cyspTranscript[idx]; cyspSentenceStart = seg.start; var endTime = seg.start + seg.dur + 0.4;
        clearTimeout(cyspPauseTimer); clearInterval(cyspProgressInterval);

        if (cyspCurrentMode === 'dictation') { cyspShowShield('Đang phát… hãy lắng nghe!'); document.getElementById('shield-reveal-btn').style.display = 'none'; }
        var cdDict = document.getElementById('dict-countdown'), cdShadow = document.getElementById('shadow-countdown'), cdShield = document.getElementById('shield-countdown'), hasStarted = false, watchInterval = null, safetyTimer = null, isDone = false;

        function cleanup() {
            if (isDone) return; isDone = true; clearInterval(watchInterval); clearTimeout(safetyTimer);
            if (cyspPlayer) cyspPlayer.pauseVideo();
            if (cdDict) cdDict.textContent = ''; if (cdShadow) cdShadow.textContent = ''; if (cdShield) cdShield.textContent = '';
            document.getElementById('shield-msg').innerHTML = 'Video đã dừng.<br>Hãy gõ / nói lại những gì bạn nghe được!';
            if (onDone) onDone();
        }

        cyspPlayer.seekTo(seg.start, true); cyspPlayer.playVideo();

        watchInterval = setInterval(function() {
            if (isDone) return;
            try {
                var state = cyspPlayer.getPlayerState(), cur = cyspPlayer.getCurrentTime();
                if (!hasStarted && state === YT.PlayerState.PLAYING && cur >= seg.start - 0.8) hasStarted = true;
                if (hasStarted) {
                    var rem = Math.ceil(endTime - cur), txt = rem > 0 ? rem + 's' : '';
                    if (cdDict) cdDict.textContent = txt; if (cdShadow) cdShadow.textContent = txt; if (cdShield) cdShield.textContent = rem > 0 ? rem : '';
                    if (cur >= endTime) cleanup();
                }
            } catch(e) { cleanup(); }
        }, 80);

        safetyTimer = setTimeout(function() { if (!isDone) cleanup(); }, (seg.dur + 8) * 1000);
    }

    function sanitizeForCompare(str) { return str ? str.replace(/[\s.,!?;:"'()\[\]{}，。！？、；：""（）《》【】]/g, '') : ''; }
    function compareTexts(t1, t2) {
        var c1 = sanitizeForCompare(t1), c2 = sanitizeForCompare(t2), len = Math.max(c1.length, c2.length), correct = 0, h1 = '', h2 = '';
        for (var i = 0; i < len; i++) {
            var a = i < c1.length ? c1[i] : '', b = i < c2.length ? c2[i] : '';
            if (a && b && a === b) { correct++; h1 += '<span class="cysp-char-ok">' + esc(a) + '</span>'; h2 += '<span class="cysp-char-ok">' + esc(b) + '</span>'; }
            else { if (a) h1 += '<span class="cysp-char-err">' + esc(a) + '</span>'; if (b) h2 += '<span class="cysp-char-err">' + esc(b) + '</span>'; }
        }
        return { pct: len ? Math.round(correct / len * 100) : 0, html1: h1, html2: h2 };
    }
    function buildResultHtml(pct, h1, h2, lo, lu) {
        var cls = pct === 100 ? 'correct' : (pct >= 60 ? 'partial' : 'wrong'), em = pct === 100 ? '✓ ' : (pct >= 60 ? '⚠ ' : '✗ ');
        return '<div class="cysp-result-box ' + cls + '"><span class="cysp-result-label">' + em + pct + '% chính xác</span><div style="font-size:13px;line-height:2;"><span style="color:#999;font-size:11px;">' + lo + '&nbsp;</span>' + h1 + '<br><span style="color:#999;font-size:11px;">' + lu + '&nbsp;</span>' + h2 + '</div></div>';
    }

