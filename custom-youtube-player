// ==========================================
// 2. XỬ LÝ AJAX TÌM KIẾM
// ==========================================
add_action('wp_ajax_cysp_search', 'cysp_handle_ajax_search');
add_action('wp_ajax_nopriv_cysp_search', 'cysp_handle_ajax_search');

function cysp_handle_ajax_search() {
    check_ajax_referer('cysp_search_secure_nonce', 'security');

    $api_key = get_option('cysp_api_key');
    if (empty($api_key)) {
        wp_send_json_error('Quản trị viên chưa cấu hình API Key.');
    }

    $query = isset($_POST['query']) ? sanitize_text_field($_POST['query']) : '';
    $order = isset($_POST['order']) ? sanitize_text_field($_POST['order']) : 'relevance';
    $duration = isset($_POST['duration']) ? sanitize_text_field($_POST['duration']) : 'any';
    $caption = isset($_POST['caption']) ? sanitize_text_field($_POST['caption']) : 'closedCaption';
    $lang = isset($_POST['lang']) ? sanitize_text_field($_POST['lang']) : 'zh-Hans';

    // Ép Phụ đề Tiếng Trung
    $api_query = $query;
    if ($caption === 'closedCaption') {
        $api_query .= ' "中文字幕"'; 
    }

    // Cache results
    $cache_key = 'cysp_yt_' . md5($api_query . $order . $duration . $caption . $lang);
    $cached_results = get_transient($cache_key);

    if ($cached_results !== false) {
        wp_send_json_success($cached_results);
    }

    $url = "https://www.googleapis.com/youtube/v3/search?part=snippet&maxResults=12&type=video&q=" . urlencode($api_query) . "&order=" . $order . "&videoDuration=" . $duration . "&relevanceLanguage=" . $lang . "&key=" . $api_key;
    
    if ($caption === 'closedCaption') {
        $url .= "&videoCaption=closedCaption";
    }
    
    $response = wp_remote_get($url);
    if (is_wp_error($response)) { wp_send_json_error('Lỗi kết nối máy chủ.'); }

    $body = wp_remote_retrieve_body($response);
    $data = json_decode($body);

    if (isset($data->error)) { wp_send_json_error($data->error->message); }

    set_transient($cache_key, $data->items, 12 * HOUR_IN_SECONDS);
    wp_send_json_success($data->items);
}

