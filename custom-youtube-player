    /* ══════════════════════════════════════════════════════════
       playSentenceByIndex — V9.1 FIX
       Theo dõi getCurrentTime() thực tế thay vì setTimeout cứng.
       Tránh dừng sớm khi YouTube cần thêm thời gian buffer/seek.
    ══════════════════════════════════════════════════════════ */
    function playSentenceByIndex(idx, onDone) {
        if (!cyspPlayer || !cyspTranscript.length) return;
        var seg = cyspTranscript[idx];
        cyspSentenceStart = seg.start;

        /* Thêm 0.4s buffer để chắc chắn audio không bị cắt sớm */
        var endTime = seg.start + seg.dur + 0.4;

        /* Dọn dẹp bất kỳ timer/interval nào đang chạy */
        clearTimeout(cyspPauseTimer);
        clearInterval(cyspProgressInterval);

        if (cyspCurrentMode === 'dictation') {
            cyspShowShield('Đang phát… hãy lắng nghe!');
            document.getElementById('shield-reveal-btn').style.display = 'none';
        }

        var cdDict   = document.getElementById('dict-countdown');
        var cdShadow = document.getElementById('shadow-countdown');
        var cdShield = document.getElementById('shield-countdown');

        var hasStarted   = false;
        var watchInterval = null;
        var safetyTimer   = null;
        var isDone        = false;

        function cleanup() {
            if (isDone) return;
            isDone = true;
            clearInterval(watchInterval);
            clearTimeout(safetyTimer);
            if (cyspPlayer) cyspPlayer.pauseVideo();
            if (cdDict)   cdDict.textContent   = '';
            if (cdShadow) cdShadow.textContent = '';
            if (cdShield) cdShield.textContent = '';
            document.getElementById('shield-msg').innerHTML =
                'Video đã dừng.<br>Hãy gõ / nói lại những gì bạn nghe được!';
            if (onDone) onDone();
        }

        cyspPlayer.seekTo(seg.start, true);
        cyspPlayer.playVideo();

        /*
         * Poll mỗi 80ms — theo dõi currentTime thực tế.
         * Chỉ bắt đầu đếm ngược sau khi player thực sự
         * đang PLAYING và đã seek đến gần vị trí đúng.
         */
        watchInterval = setInterval(function() {
            if (isDone) return;
            try {
                var state = cyspPlayer.getPlayerState();
                var cur   = cyspPlayer.getCurrentTime();

                /* Xác nhận video đã bắt đầu phát tại vị trí câu */
                if (!hasStarted && state === YT.PlayerState.PLAYING && cur >= seg.start - 0.8) {
                    hasStarted = true;
                }

                /* Cập nhật countdown chỉ khi đã bắt đầu phát */
                if (hasStarted) {
                    var rem = Math.ceil(endTime - cur);
                    var txt = rem > 0 ? rem + 's' : '';
                    if (cdDict)   cdDict.textContent   = txt;
                    if (cdShadow) cdShadow.textContent = txt;
                    if (cdShield) cdShield.textContent = rem > 0 ? rem : '';

                    /* Dừng khi đã qua endTime */
                    if (cur >= endTime) {
                        cleanup();
                    }
                }
            } catch(e) { cleanup(); }
        }, 80);

        /*
         * Safety fallback: nếu sau (dur + 8s) vẫn chưa kết thúc
         * (ví dụ: mạng cực chậm, video không load được) thì thoát.
         */
        safetyTimer = setTimeout(function() {
            if (!isDone) cleanup();
        }, (seg.dur + 8) * 1000);
    }

    function sanitizeForCompare(str) {
        if (!str) return '';
        return str.replace(/[\s.,!?;:"'()\[\]{}，。！？、；：""（）《》【】]/g, '');
    }
    function compareTexts(t1, t2) {
        var c1 = sanitizeForCompare(t1), c2 = sanitizeForCompare(t2);
        var len = Math.max(c1.length, c2.length), correct = 0, h1 = '', h2 = '';
        for (var i = 0; i < len; i++) {
            var a = i < c1.length ? c1[i] : '', b = i < c2.length ? c2[i] : '';
            if (a && b && a === b) { correct++; h1 += '<span class="cysp-char-ok">' + esc(a) + '</span>'; h2 += '<span class="cysp-char-ok">' + esc(b) + '</span>'; }
            else { if (a) h1 += '<span class="cysp-char-err">' + esc(a) + '</span>'; if (b) h2 += '<span class="cysp-char-err">' + esc(b) + '</span>'; }
        }
        return { pct: len ? Math.round(correct / len * 100) : 0, html1: h1, html2: h2 };
    }
    function buildResultHtml(pct, h1, h2, lo, lu) {
        var cls = pct === 100 ? 'correct' : (pct >= 60 ? 'partial' : 'wrong');
        var em  = pct === 100 ? '✓ ' : (pct >= 60 ? '⚠ ' : '✗ ');
        return '<div class="cysp-result-box ' + cls + '"><span class="cysp-result-label">' + em + pct + '% chính xác</span>'
            + '<div style="font-size:13px;line-height:2;"><span style="color:#999;font-size:11px;">' + lo + '&nbsp;</span>' + h1
            + '<br><span style="color:#999;font-size:11px;">' + lu + '&nbsp;</span>' + h2 + '</div></div>';
    }
    function esc(s)     { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function escAttr(s) { return esc(s).replace(/"/g,'&quot;'); }

    /* ══ DICTATION ══ */
    $('#dict-play-btn').click(function() {
        if (!cyspPlayer) return;
