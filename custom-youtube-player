    function loadTranscript(vid, lp) {
        cyspTranscript = []; cyspSentenceIndex = 0; cyspAutoPlay = false;
        $('#dict-check-btn').prop('disabled', true); $('#dict-input').prop('disabled', true).val('');
        $('#cysp-mode-toolbar').hide(); $('#cysp-dictation-panel, #cysp-shadowing-panel').hide();
        $('#cysp-transcript-error').hide().empty(); $('#cysp-transcript-loading').show();

        $.post('<?php echo $ajax_url; ?>', { action: 'cysp_get_transcript', security: '<?php echo $nonce; ?>', video_id: vid, lang: lp }, function(res) {
            $('#cysp-transcript-loading').hide();
            if (!res.success) {
                $('#cysp-mode-toolbar').hide();
                $('#cysp-transcript-error').html('<strong>Video này chưa có file Dictation/Shadowing.</strong> Đang ở chế độ Xem thường.').show();
