            }
        });
    }
    loadLocalLibrary();

    function performSearch() {
        var query = $('#cysp-search-input').val().trim();
        if (!query) { loadLocalLibrary(); return; }
        $('#cysp-results').empty(); $('#cysp-loading').show();
        $.post('<?php echo $ajax_url; ?>', {
            action: 'cysp_search', security: '<?php echo $nonce; ?>',
            query: query, lang: $('#cysp-lang').val(),
            duration: $('#cysp-duration').val(), caption: $('#cysp-caption').val()
