    /* ══ SHADOWING ══ */
    var mediaRecorder = null, audioChunks = [], recordTimer = null;
    var recordSeconds = 0, audioCtx = null, analyser = null;
    var animFrame = null, isRecording = false;
    var recognizer = null, finalRecognizedText = '';

    $('#shadow-play-btn-main').click(function() {
        if (!cyspPlayer) return;
        cyspAutoPlay = true;
        if (isRecording) stopRecording(true);
        $('#shadow-result').hide();
        playSentenceByIndex(cyspSentenceIndex, function() {
            document.getElementById('shield-reveal-btn').style.display = 'inline-block';
            startRecording();
        });
    });

    function startRecording() {
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) { alert('Trình duyệt không hỗ trợ thu âm.'); return; }
        if (typeof SpeechSDK === 'undefined') { alert('Thư viện Azure AI đang tải, vui lòng đợi và thử lại.'); return; }
        if (!AZURE_KEY || !AZURE_REGION) { alert('Admin chưa cấu hình Azure Speech Key & Region!'); return; }
        $('#shadow-result').hide(); finalRecognizedText = '';
        navigator.mediaDevices.getUserMedia({ audio: true }).then(function(stream) {
            cyspBeep(); isRecording = true; audioChunks = [];
            $('#shadow-ctrl-idle').hide(); $('#shadow-ctrl-rec').show();
            $('#shadow-rec-idle').hide(); $('#shadow-rec-live').show();
            $('#shadow-clear-rec-btn').hide(); $('#shadow-playback-row').hide();
            mediaRecorder = new MediaRecorder(stream);
            mediaRecorder.start();
            mediaRecorder.addEventListener('dataavailable', function(e) { audioChunks.push(e.data); });
            mediaRecorder.addEventListener('stop', function() {
                var blob = new Blob(audioChunks, { type: 'audio/webm' });
                document.getElementById('shadow-audio').src = URL.createObjectURL(blob);
                stream.getTracks().forEach(function(t) { t.stop(); });
            });
            recordSeconds = 0; updateRecTimer();
            recordTimer = setInterval(updateRecTimer, 1000);
            audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            analyser  = audioCtx.createAnalyser();
            audioCtx.createMediaStreamSource(stream).connect(analyser);
            drawWaveform();
            var speechConfig = SpeechSDK.SpeechConfig.fromSubscription(AZURE_KEY, AZURE_REGION);
            speechConfig.speechRecognitionLanguage = $('#cysp-lang').val() === 'zh-Hant' ? 'zh-TW' : 'zh-CN';
            var audioConfig = SpeechSDK.AudioConfig.fromDefaultMicrophoneInput();
            recognizer = new SpeechSDK.SpeechRecognizer(speechConfig, audioConfig);
            recognizer.recognized = function(s, e) {
                if (e.result.reason === SpeechSDK.ResultReason.RecognizedSpeech)
                    finalRecognizedText += e.result.text + ' ';
            };
            recognizer.canceled = function() { stopRecording(true); };
            recognizer.startContinuousRecognitionAsync(function(){}, function(err){ alert('Lỗi Azure: '+err); stopRecording(true); });
        }).catch(function() { $('#shadow-idle-label').text('Không thể truy cập micro.'); });
    }

    function stopRecording(isError) {
        if (!isRecording) return;
        isRecording = false;
        if (mediaRecorder) mediaRecorder.stop();
        clearInterval(recordTimer);
        cancelAnimationFrame(animFrame);
        $('#shadow-ctrl-rec').hide(); $('#shadow-ctrl-idle').show();
        $('#shadow-rec-live').hide(); $('#shadow-rec-idle').show();
        $('#shadow-idle-label').text('Bản ghi âm');
        $('#shadow-clear-rec-btn').show();
        $('#shadow-playback-row').css('display', 'flex');
        clearCanvas();
        if (recognizer) {
            $('#shadow-result').html('<em style="font-size:13px;color:#888;">AI đang phân tích…</em>').show();
            recognizer.stopContinuousRecognitionAsync(function() {
                recognizer.close(); recognizer = undefined;
                if (isError !== true) processAzureResult();
            });
        }
    }

    function processAzureResult() {
        if (finalRecognizedText.trim()) {
            var origText = cyspTranscript.length ? cyspTranscript[cyspSentenceIndex].text : '';
            var res = compareTexts(origText, finalRecognizedText);
            $('#shadow-result').html(buildResultHtml(res.pct, res.html1, res.html2, 'Câu gốc:', 'AI nghe bạn:')).show();
        } else {
            $('#shadow-result').html('<div class="cysp-result-box wrong"><span class="cysp-result-label">AI không nghe rõ</span>Hãy nói to, rõ ràng và thử lại nhé!</div>').show();
        }
        $('#shadow-sentence-text').addClass('revealed');
    }

    function updateRecTimer() {
        recordSeconds++;
        var m = Math.floor(recordSeconds / 60), s = recordSeconds % 60;
        $('#shadow-timer').text((m < 10 ? '0' + m : m) + ':' + (s < 10 ? '0' + s : s));
        if (recordSeconds >= 10) stopRecording();
    }

    function drawWaveform() {
        var cv = document.getElementById('shadow-canvas');
        cv.width = cv.parentElement.clientWidth - 20;
        var cx = cv.getContext('2d'), W = cv.width, H = cv.height;
        analyser.fftSize = 256;
        var buf = new Uint8Array(analyser.frequencyBinCount);
        (function draw() {
            animFrame = requestAnimationFrame(draw);
            analyser.getByteTimeDomainData(buf);
            cx.fillStyle = '#0f0f1a'; cx.fillRect(0, 0, W, H);
            cx.lineWidth = 1.5; cx.strokeStyle = '#d32f2f'; cx.beginPath();
            var sw = W / buf.length, x = 0;
            for (var i = 0; i < buf.length; i++) {
                var y = buf[i] / 128 * H / 2;
                i === 0 ? cx.moveTo(x, y) : cx.lineTo(x, y);
                x += sw;
            }
            cx.lineTo(W, H / 2); cx.stroke();
        })();
    }

    function clearCanvas() {
        var cv = document.getElementById('shadow-canvas');
        cv.width = cv.parentElement ? cv.parentElement.clientWidth - 20 : 300;
        var cx = cv.getContext('2d');
        cx.fillStyle = '#0f0f1a'; cx.fillRect(0, 0, cv.width, cv.height);
        cx.strokeStyle = 'rgba(255,255,255,.1)'; cx.lineWidth = 0.5;
        cx.beginPath(); cx.moveTo(0, cv.height/2); cx.lineTo(cv.width, cv.height/2); cx.stroke();
    }

    $('#shadow-stop-btn').click(function()  { stopRecording(); });
    $('#shadow-listen-btn').click(function() { document.getElementById('shadow-audio').play(); });
    $('#shadow-clear-rec-btn').click(function() {
        document.getElementById('shadow-audio').src = '';
        $('#shadow-playback-row').hide(); $('#shadow-clear-rec-btn').hide();
        $('#shadow-idle-label').text('Nhấn Phát để bắt đầu');
        recordSeconds = 0; $('#shadow-timer').text('00:00');
        clearCanvas(); $('#shadow-result').hide();
    });

    clearCanvas();
    $(window).on('resize', function() { if (!isRecording) clearCanvas(); });

}); /* end jQuery ready */
