    </style>

    <script type="text/javascript">
        jQuery(document).ready(function($) {
            function performSearch() {
                var query = $('#cysp-search-input').val().trim();
                if (!query) return;
                
                $('#cysp-results').empty();
                $('#cysp-loading').fadeIn();
                
                $.post('<?php echo $ajax_url; ?>', {
                    action: 'cysp_search',
                    security: '<?php echo $nonce; ?>',
                    query: query,
                    lang: $('#cysp-lang').val(),
                    duration: $('#cysp-duration').val(),
                    caption: $('#cysp-caption').val()
                }, function(response) {
                    $('#cysp-loading').hide();
                    if (response.success) {
                        $.each(response.data, function(i, item) {
                            var html = '<div class="cysp-item" data-vid="'+item.id.videoId+'">';
                            html += '<div class="cysp-thumb-wrap"><img src="'+item.snippet.thumbnails.medium.url+'" />';
                            if($('#cysp-caption').val() === 'closedCaption') html += '<span class="cysp-cc-badge">CC</span>';
                            html += '</div><div class="cysp-info">';
                            html += '<h4 class="cysp-title">'+item.snippet.title+'</h4>';
                            html += '<p class="cysp-channel">📺 '+item.snippet.channelTitle+'</p>';
                            html += '</div></div>';
                            $('#cysp-results').append(html);
                        });
                    }
                });
            }

            $('#cysp-search-btn').click(performSearch);
            $('#cysp-search-input').keypress(function(e) { if (e.which === 13) performSearch(); });
            $('.cysp-tag').click(function() {
                $('#cysp-search-input').val($(this).data('kw'));
                performSearch();
            });

            $(document).on('click', '.cysp-item', function() {
                var vidId = $(this).data('vid');
                var lp = $('#cysp-lang').val() === 'zh-Hant' ? 'zh-TW' : 'zh-CN';
                $('#cysp-iframe').attr('src', 'https://www.youtube.com/embed/' + vidId + '?autoplay=1&cc_load_policy=1&hl='+lp+'&cc_lang_pref='+lp);
                $('#cysp-player-container').slideDown();
                $('html, body').animate({ scrollTop: $("#cysp-container").offset().top - 20 }, 500);
            });
        });
    </script>
    <?php
}
