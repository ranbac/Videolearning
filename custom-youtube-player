// ==========================================
// 2A. HÀM HỖ TRỢ ĐỌC FILE SRT & LẤY LOCAL METADATA
// ==========================================
function cysp_parse_local_srt($file_path) {
    $content = file_get_contents($file_path);
    $content = preg_replace('/^\xEF\xBB\xBF/', '', $content);
    $content = str_replace(["\r\n", "\r"], "\n", $content);
    $blocks  = explode("\n\n", trim($content));
    $segments = [];
    foreach ($blocks as $block) {
        $lines = explode("\n", $block);
        if (count($lines) < 3) continue;
        $time_line = $lines[1];
        if (preg_match('/(\d{2}):(\d{2}):(\d{2}),(\d{3})\s*-->\s*(\d{2}):(\d{2}):(\d{2}),(\d{3})/', $time_line, $m)) {
            $start = ($m[1]*3600) + ($m[2]*60) + $m[3] + ($m[4]/1000);
            $end   = ($m[5]*3600) + ($m[6]*60) + $m[7] + ($m[8]/1000);
            $dur   = $end - $start;
            $text_lines = array_slice($lines, 2);
            $text = implode(" ", $text_lines);
            $text = strip_tags($text);
            $segments[] = [
                'start' => round($start, 3),
                'dur'   => round($dur, 3),
                'text'  => trim($text),
            ];
        }
    }
    return $segments;
}

function cysp_get_all_local_videos_metadata($api_key, $transcript_dir) {
    if (!file_exists($transcript_dir)) return [];
    $files = scandir($transcript_dir);
    $video_ids = [];
    foreach ($files as $file) {
        if (preg_match('/^([a-zA-Z0-9_-]{11})\.(srt|json)$/', $file, $m)) $video_ids[$m[1]] = true;
    }
    $video_ids = array_keys($video_ids);
    if (empty($video_ids)) return [];

    $ids_string = implode(',', $video_ids);
    $cache_key = 'cysp_loc_meta_all_' . md5($ids_string);
    $cached = get_transient($cache_key);
    if ($cached !== false) return $cached;

    $all_items = [];
    $chunks = array_chunk($video_ids, 50);
    foreach ($chunks as $chunk) {
        $chunk_str = implode(',', $chunk);
        $url = "https://www.googleapis.com/youtube/v3/videos?part=snippet&id={$chunk_str}&key={$api_key}";
        $response = wp_remote_get($url);
        if (!is_wp_error($response)) {
            $data = json_decode(wp_remote_retrieve_body($response));
            if (!empty($data->items)) {
                foreach ($data->items as $item) {
                    $item->id = (object) ['videoId' => $item->id];
                    $all_items[] = $item;
                }
            }
        }
    }
    set_transient($cache_key, $all_items, 12 * HOUR_IN_SECONDS);
    return $all_items;
}

