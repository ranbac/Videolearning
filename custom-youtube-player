<script>
const AZURE_KEY    = "<?php echo esc_js($azure_key); ?>";
const AZURE_REGION = "<?php echo esc_js($azure_region); ?>";

var cyspPlayer           = null;
var cyspCurrentMode      = 'normal';
var cyspSentenceStart    = 0;
var cyspPauseTimer       = null;
var cyspProgressInterval = null;
var cyspCurrentVid       = '';
var cyspCurrentLp        = 'zh-CN';
var cyspRevealOnPlay     = false;
var cyspAutoPlay         = false;

/* ── Custom player state ── */
var cyspDuration      = 0;
var cyspProgressRAF   = null;
var cyspIsSeeking     = false;
var cyspControlsTimer = null;

function onYouTubeIframeAPIReady() { }

/* ── Format seconds → m:ss ── */
function cyspFmtTime(s) {
    if (isNaN(s) || s < 0) return '0:00';
    s = Math.floor(s);
    var m = Math.floor(s / 60), ss = s % 60;
    return m + ':' + (ss < 10 ? '0' : '') + ss;
}

/* ── Update progress bar ── */
function cyspUpdateProgress() {
    if (!cyspPlayer || cyspIsSeeking) return;
    try {
        var cur = cyspPlayer.getCurrentTime() || 0;
        var dur = cyspPlayer.getDuration()    || 0;
        if (dur > 0) {
            var pct = cur / dur * 100;
            document.getElementById('cysp-progress-fill').style.width  = pct + '%';
            document.getElementById('cysp-progress-thumb').style.left  = pct + '%';
            document.getElementById('cysp-progress-wrap').setAttribute('aria-valuenow', Math.round(pct));
        }
        document.getElementById('cysp-time-display').textContent =
            cyspFmtTime(cur) + ' / ' + cyspFmtTime(dur);
    } catch(e) {}
}

function cyspStartProgressLoop() {
    cyspUpdateProgress();
    cyspProgressRAF = requestAnimationFrame(cyspStartProgressLoop);
}
function cyspStopProgressLoop() {
    if (cyspProgressRAF) { cancelAnimationFrame(cyspProgressRAF); cyspProgressRAF = null; }
}

/* ── Show/hide controls on mouse activity ── */
function cyspResetControlsTimer() {
    var p = document.getElementById('cysp-custom-player');
    p.classList.add('cysp-controls-visible');
    clearTimeout(cyspControlsTimer);
    cyspControlsTimer = setTimeout(function() {
        if (cyspPlayer && cyspPlayer.getPlayerState && cyspPlayer.getPlayerState() === 1) {
            p.classList.remove('cysp-controls-visible');
        }
    }, 2800);
}

function cyspInitPlayer(videoId, langPref) {
    if (typeof YT === 'undefined' || typeof YT.Player === 'undefined') {
        alert('⏳ Trình phát video đang khởi tạo. Vui lòng đợi 2 giây rồi bấm lại nhé!');
        return false;
    }
    cyspCurrentVid = videoId;
    cyspCurrentLp  = langPref;

    if (cyspPlayer) {
        cyspPlayer.loadVideoById(videoId);
        return true;
    }

    cyspPlayer = new YT.Player('cysp-yt-player', {
        videoId: videoId,
        host: 'https://www.youtube-nocookie.com',
        playerVars: {
            autoplay:       1,
            cc_load_policy: 1,
            hl:             langPref,
            cc_lang_pref:   langPref,
            rel:            0,
            modestbranding: 1,
            iv_load_policy: 3,
            disablekb:      1,
            fs:             0,
            playsinline:    1,
            controls:       0,
            showinfo:       0,
        },
        events: {
            onReady: function(e) {
                e.target.playVideo();
                cyspStartProgressLoop();
                try {
                    var v = e.target.getVolume();
                    document.getElementById('cysp-vol-input').value = v;
                    document.getElementById('cysp-vol-fill').style.width = v + '%';
                } catch(err) {}
            },
            onStateChange: function(e) {
                var pp   = document.getElementById('cysp-playpause-btn');
                var play = pp.querySelector('.icon-play');
                var paus = pp.querySelector('.icon-pause');
                if (e.data === YT.PlayerState.PLAYING) {
                    play.style.display = 'none';
                    paus.style.display = '';
                    cyspStartProgressLoop();
                    if (cyspRevealOnPlay) { cyspRevealOnPlay = false; cyspHideShield(); }
                } else {
                    play.style.display = '';
                    paus.style.display = 'none';
                    if (e.data !== YT.PlayerState.BUFFERING) cyspStopProgressLoop();
                }
                if (e.data === YT.PlayerState.ENDED) { cyspRevealOnPlay = false; cyspHideShield(); }
                cyspResetControlsTimer();
            }
        }
    });
    return true;
}

function cyspShowShield(msgHtml) {
    var s = document.getElementById('cysp-shield');
    if (msgHtml) document.getElementById('shield-msg').innerHTML = msgHtml;
    s.classList.add('active');
}
function cyspHideShield() {
    cyspRevealOnPlay = false;
    document.getElementById('cysp-shield').classList.remove('active');
    document.getElementById('shield-reveal-btn').style.display = 'none';
    document.getElementById('shield-countdown').textContent = '';
}
function cyspRevealAndReplay() {
    if (!cyspPlayer) { cyspHideShield(); return; }
    cyspRevealOnPlay = true;
    cyspPlayer.seekTo(cyspSentenceStart, true);
    cyspPlayer.playVideo();
}

function cyspBeep() {
    try {
        var ctx  = new (window.AudioContext || window.webkitAudioContext)();
        var osc  = ctx.createOscillator();
        var gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.frequency.value = 880;
        gain.gain.setValueAtTime(0.3, ctx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.18);
        osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.18);
    } catch(e) {}
}

jQuery(document).ready(function($) {

    /* ══ CUSTOM PLAYER CONTROLS ══ */

    /* Play / Pause button */
    $('#cysp-playpause-btn').click(function() {
        if (!cyspPlayer) return;
        var state = cyspPlayer.getPlayerState();
        if (state === YT.PlayerState.PLAYING) cyspPlayer.pauseVideo();
        else cyspPlayer.playVideo();
        cyspResetControlsTimer();
    });

    /* Click trên player (ngoài controls) → toggle play/pause */
    $('#cysp-iframe-blocker').click(function() {
        if (!cyspPlayer) return;
        var state = cyspPlayer.getPlayerState();
        if (state === YT.PlayerState.PLAYING) cyspPlayer.pauseVideo();
        else cyspPlayer.playVideo();
        cyspResetControlsTimer();
    });

    /* Mouse move → hiện controls */
    $('#cysp-custom-player').on('mousemove touchstart', cyspResetControlsTimer);

    /* ── Seek bar ── */
    var progressWrap  = document.getElementById('cysp-progress-wrap');
    var progressFill  = document.getElementById('cysp-progress-fill');
    var progressThumb = document.getElementById('cysp-progress-thumb');
    var progressTip   = document.getElementById('cysp-progress-tooltip');

    function getSeekPct(e) {
        var rect = progressWrap.getBoundingClientRect();
        var x    = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left;
        return Math.max(0, Math.min(1, x / rect.width));
    }

    $(progressWrap).on('mousemove touchmove', function(e) {
        e.preventDefault();
        var pct = getSeekPct(e.originalEvent);
        var dur = cyspPlayer ? (cyspPlayer.getDuration() || 0) : 0;
        progressTip.textContent  = cyspFmtTime(pct * dur);
        progressTip.style.left   = (pct * 100) + '%';
        if (cyspIsSeeking) {
            progressFill.style.width = (pct * 100) + '%';
            progressThumb.style.left = (pct * 100) + '%';
        }
    }).on('mousedown touchstart', function(e) {
        cyspIsSeeking = true;
        var pct = getSeekPct(e.originalEvent);
        progressFill.style.width = (pct * 100) + '%';
        progressThumb.style.left = (pct * 100) + '%';
    }).on('mouseup touchend click', function(e) {
        var pct = getSeekPct(e.originalEvent);
        if (cyspPlayer) {
            var dur = cyspPlayer.getDuration() || 0;
            cyspPlayer.seekTo(pct * dur, true);
        }
        cyspIsSeeking = false;
        cyspResetControlsTimer();
    });
    $(document).on('mouseup', function() { cyspIsSeeking = false; });

    /* ── Speed dropdown ── */
    $('#cysp-speed-btn').click(function(e) {
        e.stopPropagation();
        $('#cysp-speed-dropdown').toggleClass('open');
        cyspResetControlsTimer();
    });
    $(document).on('click', function() { $('#cysp-speed-dropdown').removeClass('open'); });
    $(document).on('click', '.cysp-speed-opt', function() {
        var rate = parseFloat($(this).data('rate'));
        if (cyspPlayer) cyspPlayer.setPlaybackRate(rate);
        $('.cysp-speed-opt').removeClass('cysp-speed-opt--active');
        $(this).addClass('cysp-speed-opt--active');
        $('#cysp-speed-label').text($(this).text());
        $('#cysp-speed-dropdown').removeClass('open');
        /* Sync shadowing pills */
        $('.cysp-speed-pill').removeClass('cysp-speed-pill--active').attr('aria-pressed','false');
        $('.cysp-speed-pill[data-rate="' + rate + '"]').addClass('cysp-speed-pill--active').attr('aria-pressed','true');
    });

    /* ── Volume ── */
    $('#cysp-vol-input').on('input', function() {
        var v = parseInt($(this).val());
        if (cyspPlayer) cyspPlayer.setVolume(v);
        $('#cysp-vol-fill').css('width', v + '%');
        var volIcon  = $('#cysp-mute-btn .icon-vol')[0];
        var muteIcon = $('#cysp-mute-btn .icon-mute')[0];
        if (v === 0) { volIcon.style.display = 'none'; muteIcon.style.display = ''; }
        else         { volIcon.style.display = '';     muteIcon.style.display = 'none'; }
    });
    $('#cysp-mute-btn').click(function() {
        if (!cyspPlayer) return;
        var inp = $('#cysp-vol-input');
        if (cyspPlayer.isMuted()) {
            cyspPlayer.unMute();
            var v = cyspPlayer.getVolume();
            inp.val(v); $('#cysp-vol-fill').css('width', v + '%');
            $(this).find('.icon-vol').show();
            $(this).find('.icon-mute').hide();
        } else {
            cyspPlayer.mute();
            $(this).find('.icon-vol').hide();
            $(this).find('.icon-mute').show();
        }
    });

    /* ── Fullscreen ── */
    $('#cysp-fs-btn').click(function() {
        var el = document.getElementById('cysp-custom-player');
        if (!document.fullscreenElement) {
            (el.requestFullscreen || el.webkitRequestFullscreen || el.mozRequestFullScreen).call(el);
        } else {
            (document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen).call(document);
        }
    });

    /* Shadowing speed pills → sync player */
    $('.cysp-speed-pill').click(function() {
        $('.cysp-speed-pill').removeClass('cysp-speed-pill--active').attr('aria-pressed', 'false');
        $(this).addClass('cysp-speed-pill--active').attr('aria-pressed', 'true');
        var rate = parseFloat($(this).data('rate'));
        if (cyspPlayer) cyspPlayer.setPlaybackRate(rate);
        /* Sync speed dropdown */
        $('.cysp-speed-opt').removeClass('cysp-speed-opt--active');
        $('.cysp-speed-opt[data-rate="' + rate + '"]').addClass('cysp-speed-opt--active');
        $('#cysp-speed-label').text(rate + '×');
    });

    /* ══ BUILD VIDEO CARD ══ */
