<script>
const AZURE_KEY    = "<?php echo esc_js($azure_key); ?>";
const AZURE_REGION = "<?php echo esc_js($azure_region); ?>";

var cyspPlayer           = null;
var cyspCurrentMode      = 'normal';
var cyspSentenceStart    = 0;
var cyspPauseTimer       = null;
var cyspProgressInterval = null;
var cyspCurrentVid       = '';
var cyspCurrentLp        = 'zh-CN';
var cyspCurrentMeta      = null; 
var cyspRevealOnPlay     = false;
var cyspAutoPlay         = false;

var cyspDuration      = 0;
var cyspProgressRAF   = null;
var cyspIsSeeking     = false;
var cyspControlsTimer = null;

// ==========================================
// SESSION RESTORE HELPERS
// ==========================================
var CYSP_SS_VID  = 'cysp_vid';
var CYSP_SS_LP   = 'cysp_lp';
var CYSP_SS_MODE = 'cysp_mode';
var CYSP_SS_IDX  = 'cysp_idx';
var CYSP_SS_TIME = 'cysp_time';

function cyspSaveSession() {
    try {
        sessionStorage.setItem(CYSP_SS_VID,  cyspCurrentVid);
        sessionStorage.setItem(CYSP_SS_LP,   cyspCurrentLp);
        sessionStorage.setItem(CYSP_SS_MODE, cyspCurrentMode);
        sessionStorage.setItem(CYSP_SS_IDX,  cyspSentenceIndex || 0);
        if (cyspPlayer) {
            try { sessionStorage.setItem(CYSP_SS_TIME, cyspPlayer.getCurrentTime() || 0); } catch(e) {}
        }
    } catch(e) {}
}

function cyspClearSession() {
    try {
        sessionStorage.removeItem(CYSP_SS_VID);
        sessionStorage.removeItem(CYSP_SS_LP);
        sessionStorage.removeItem(CYSP_SS_MODE);
        sessionStorage.removeItem(CYSP_SS_IDX);
        sessionStorage.removeItem(CYSP_SS_TIME);
    } catch(e) {}
}

function cyspGetSession() {
    try {
        var vid = sessionStorage.getItem(CYSP_SS_VID);
        if (!vid) return null;
        return {
            vid:  vid,
            lp:   sessionStorage.getItem(CYSP_SS_LP)   || 'zh-CN',
            mode: sessionStorage.getItem(CYSP_SS_MODE) || 'normal',
            idx:  parseInt(sessionStorage.getItem(CYSP_SS_IDX) || '0', 10),
            time: parseFloat(sessionStorage.getItem(CYSP_SS_TIME) || '0'),
        };
    } catch(e) { return null; }
}

// ==========================================
// LỊCH SỬ ĐÃ HỌC (LOCAL STORAGE)
// ==========================================
function cyspUpdateHistoryRecord(vid, title, thumb, channel, total, idx) {
    try {
        var hist = JSON.parse(localStorage.getItem('cysp_history') || '{}');
        hist[vid] = {
            vid: vid,
            title: title || (hist[vid] ? hist[vid].title : 'Bài tập'),
            thumb: thumb || (hist[vid] ? hist[vid].thumb : ''),
            channel: channel || (hist[vid] ? hist[vid].channel : ''),
            total: total > 0 ? total : (hist[vid] ? hist[vid].total : 1),
            lastIdx: hist[vid] ? Math.max(hist[vid].lastIdx, idx) : idx,
            lastDate: Date.now()
        };
        localStorage.setItem('cysp_history', JSON.stringify(hist));
        cyspRenderHistoryTab();
    } catch(e){}
}

function cyspFmtDate(ms) {
    var d = new Date(ms);
    return d.getDate().toString().padStart(2, '0') + '/' + (d.getMonth() + 1).toString().padStart(2, '0') + '/' + d.getFullYear();
}

function cyspRenderHistoryTab() {
    try {
        var hist = JSON.parse(localStorage.getItem('cysp_history') || '{}');
        var arr = Object.values(hist).sort(function(a, b) { return b.lastDate - a.lastDate; });
        if (arr.length > 0) {
            jQuery('#cysp-main-tabs').show();
            jQuery('#cysp-history-count').text(arr.length);
        } else {
            jQuery('#cysp-main-tabs').hide();
        }

        var html = '';
        for (var i = 0; i < arr.length; i++) {
            var item = arr[i];
            var pct = item.total > 0 ? Math.min(100, Math.round(((item.lastIdx + 1) / item.total) * 100)) : 0;
            var dt = cyspFmtDate(item.lastDate);
            html += '<div class="cysp-item cysp-history-item" data-vid="'+item.vid+'" data-title="'+escAttr(item.title)+'" data-thumb="'+escAttr(item.thumb)+'" data-channel="'+escAttr(item.channel)+'">';
            html += '<div class="cysp-thumb-wrap"><img src="'+escAttr(item.thumb)+'" loading="lazy"><span class="cysp-cc-badge cysp-cc-badge--local">Đã học</span></div>';
            html += '<div class="cysp-card-info">';
            html += '<h4 class="cysp-card-title">'+esc(item.title)+'</h4>';
            html += '<p class="cysp-card-channel"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="15" rx="2"/><polyline points="17 2 12 7 7 2"/></svg>'+esc(item.channel)+'</p>';
            html += '<div class="cysp-history-progress"><div class="cysp-hp-bar"><div class="cysp-hp-fill" style="width:'+pct+'%"></div></div>';
            html += '<div class="cysp-hp-meta"><span>Đã học: '+(item.lastIdx + 1)+'/'+item.total+' câu</span><span>'+dt+'</span></div>';
            html += '</div></div></div>';
        }
        jQuery('#cysp-history-grid').html(html);
    } catch(e){}
}

function onYouTubeIframeAPIReady() { }

function cyspFmtTime(s) {
    if (isNaN(s) || s < 0) return '0:00';
    s = Math.floor(s);
    var m = Math.floor(s / 60), ss = s % 60;
    return m + ':' + (ss < 10 ? '0' : '') + ss;
}

function cyspUpdateProgress() {
    if (!cyspPlayer || cyspIsSeeking) return;
    try {
        var cur = cyspPlayer.getCurrentTime() || 0;
        var dur = cyspPlayer.getDuration()    || 0;
        if (dur > 0) {
            var pct = cur / dur * 100;
            document.getElementById('cysp-progress-fill').style.width  = pct + '%';
            document.getElementById('cysp-progress-thumb').style.left  = pct + '%';
            document.getElementById('cysp-progress-wrap').setAttribute('aria-valuenow', Math.round(pct));
        }
        document.getElementById('cysp-time-display').textContent = cyspFmtTime(cur) + ' / ' + cyspFmtTime(dur);
    } catch(e) {}
}

function cyspStartProgressLoop() { cyspUpdateProgress(); cyspProgressRAF = requestAnimationFrame(cyspStartProgressLoop); }
function cyspStopProgressLoop() { if (cyspProgressRAF) { cancelAnimationFrame(cyspProgressRAF); cyspProgressRAF = null; } }

function cyspResetControlsTimer() {
    var p = document.getElementById('cysp-custom-player');
    p.classList.add('cysp-controls-visible');
    clearTimeout(cyspControlsTimer);
    cyspControlsTimer = setTimeout(function() {
        if (cyspPlayer && cyspPlayer.getPlayerState && cyspPlayer.getPlayerState() === 1) {
            p.classList.remove('cysp-controls-visible');
        }
    }, 2800);
}

function cyspInitPlayer(videoId, langPref) {
    if (typeof YT === 'undefined' || typeof YT.Player === 'undefined') {
        alert('⏳ Trình phát video đang khởi tạo. Vui lòng đợi 2 giây rồi bấm lại nhé!');
        return false;
    }
    cyspCurrentVid = videoId;
    cyspCurrentLp  = langPref;

    if (cyspPlayer) {
        cyspPlayer.loadVideoById(videoId);
        return true;
    }

    cyspPlayer = new YT.Player('cysp-yt-player', {
        videoId: videoId,
        host: 'https://www.youtube-nocookie.com',
        playerVars: { autoplay: 1, cc_load_policy: 1, hl: langPref, cc_lang_pref: langPref, rel: 0, modestbranding: 1, iv_load_policy: 3, disablekb: 1, fs: 0, playsinline: 1, controls: 0, showinfo: 0 },
        events: {
            onReady: function(e) {
                e.target.playVideo(); cyspStartProgressLoop();
                try { var v = e.target.getVolume(); document.getElementById('cysp-vol-input').value = v; document.getElementById('cysp-vol-fill').style.width = v + '%'; } catch(err) {}
            },
            onStateChange: function(e) {
                var pp = document.getElementById('cysp-playpause-btn'), play = pp.querySelector('.icon-play'), paus = pp.querySelector('.icon-pause');
                if (e.data === YT.PlayerState.PLAYING) {
                    play.style.display = 'none'; paus.style.display = ''; cyspStartProgressLoop();
                    if (cyspRevealOnPlay) { cyspRevealOnPlay = false; cyspHideShield(); }
                } else {
                    play.style.display = ''; paus.style.display = 'none';
                    if (e.data !== YT.PlayerState.BUFFERING) cyspStopProgressLoop();
                }
                if (e.data === YT.PlayerState.ENDED) { cyspRevealOnPlay = false; cyspHideShield(); }
                cyspResetControlsTimer();
            }
        }
    });
    return true;
}

function cyspShowShield(msgHtml) {
    var s = document.getElementById('cysp-shield');
    if (msgHtml) document.getElementById('shield-msg').innerHTML = msgHtml;
    s.classList.add('active');
}
function cyspHideShield() {
    cyspRevealOnPlay = false;
    document.getElementById('cysp-shield').classList.remove('active');
    document.getElementById('shield-reveal-btn').style.display = 'none';
    document.getElementById('shield-countdown').textContent = '';
}
function cyspRevealAndReplay() {
    if (!cyspPlayer) { cyspHideShield(); return; }
    cyspRevealOnPlay = true;
    cyspPlayer.seekTo(cyspSentenceStart, true);
    cyspPlayer.playVideo();
}
function cyspBeep() { try { var ctx = new (window.AudioContext || window.webkitAudioContext)(), osc = ctx.createOscillator(), gain = ctx.createGain(); osc.connect(gain); gain.connect(ctx.destination); osc.frequency.value = 880; gain.gain.setValueAtTime(0.3, ctx.currentTime); gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.18); osc.start(ctx.currentTime); osc.stop(ctx.currentTime + 0.18); } catch(e) {} }

function esc(s)     { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
function escAttr(s) { return esc(s).replace(/"/g,'&quot;'); }

