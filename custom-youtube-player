    function selectSentence(idx) {
        if (!cyspTranscript || !cyspTranscript.length) return;
        idx = Math.max(0, Math.min(idx, cyspTranscript.length - 1));
        cyspSentenceIndex = idx;
        var seg   = cyspTranscript[idx];
        var label = (idx + 1) + '/' + cyspTranscript.length;
        $('#dict-sentence-text').text(seg.text).removeClass('revealed').addClass('cysp-sentence-text--blur');
        $('#shadow-sentence-text').text(seg.text).removeClass('revealed');
        $('#dict-sentence-idx, #shadow-sentence-idx').text(label);
        $('#dict-sentence-display, #shadow-sentence-display').show();
        $('#dict-countdown, #shadow-countdown').text('');
        cyspSentenceStart = seg.start;
        $('#dict-input').val('').prop('disabled', true); $('#dict-check-btn').prop('disabled', true);
        $('#dict-result, #shadow-result').hide(); $('#shadow-audio').attr('src', '');
        $('#shadow-playback-row').hide(); $('#shadow-clear-rec-btn').hide(); $('#shadow-idle-label').text('Nhấn Phát để bắt đầu');

        cyspSaveSession();
        // Cập nhật record tiến độ
        cyspUpdateHistoryRecord(cyspCurrentVid, null, null, null, cyspTranscript.length, idx);

        if (cyspAutoPlay && cyspCurrentMode !== 'normal' && cyspPlayer) {
            if (cyspCurrentMode === 'dictation') {
                playSentenceByIndex(idx, function() { $('#dict-input').prop('disabled', false).focus(); $('#dict-check-btn').prop('disabled', false); });
            }
            if (cyspCurrentMode === 'shadowing') {
                if (isRecording) stopRecording(true);
                playSentenceByIndex(idx, function() { document.getElementById('shield-reveal-btn').style.display = 'inline-block'; startRecording(); });
            }
        }
    }

    $('#dict-prev-btn, #shadow-prev-btn').click(function() { if (cyspTranscript.length) { cyspAutoPlay = true; selectSentence(cyspSentenceIndex - 1); } });
    $('#dict-next-btn, #shadow-next-btn').click(function() { if (cyspTranscript.length) { cyspAutoPlay = true; selectSentence(cyspSentenceIndex + 1); } });

    function switchMode(mode) {
        cyspCurrentMode = mode; cyspAutoPlay = false; cyspSaveSession();
        $('.cysp-mode-btn').removeClass('active').attr('aria-selected', 'false'); $('.cysp-mode-btn[data-mode="' + mode + '"]').addClass('active').attr('aria-selected', 'true');
