            + '</div></div>';
    }

    function loadLocalLibrary() {
        $('#cysp-loading').show();
        $.post('<?php echo $ajax_url; ?>', { action: 'cysp_get_local_videos', security: '<?php echo $nonce; ?>' }, function(res) {
